{
  "name": "kakebo",
  "version": "1.0.0",
  "description": "Sistema de Controle Financeiro Pessoal - Kakebo",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "vercel-build": "npm run prisma:generate && cd frontend && npm install && npm run build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "uuid": "^14.0.0",
    "zod": "^3.23.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.13.0",
    "supertest": "^7.2.2",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5",
    "vitest": "^4.1.9"
  }
}
